        SNAP["Bootstrap Process Snapshot"]
        ENGINE["correlation/engine.go"]
        MODELS["correlation/models.go"]
        PROC["process/collector.go"]
        ENRICH["process_enrichment_update"]
    end

    subgraph Output["Output Pipeline"]
        MIXED["logger/file_sink.go"]
