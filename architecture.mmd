    PROC --> SNAP
    SNAP --> ENGINE
    EVENTS --> ENGINE
    DNS --> ENGINE
    FS --> ENGINE
    MODELS --> ENGINE
    ENGINE --> ENRICH

    ENGINE --> MIXED
    ENGINE --> OUTF
    ENGINE --> STDOUT
    ENRICH --> MIXED
    ENRICH --> OUTF
    ENRICH --> STDOUT

    OUTF --> APPOUT
    OUTF --> PROCOUT
    OUTF --> NETOUT

    MIXED --> CLOUD
    APPOUT --> CLOUD
    PROCOUT --> CLOUD
    NETOUT --> CLOUD
