flowchart TD
    subgraph External["External Systems"]
        WIN["Windows Kernel ETW"]
        REG["Windows Registry"]
        FS["Filesystem / Binary Metadata"]
        DNS["Reverse DNS"]
        CLOUD["Cloud / SIEM Consumer"]
    end

    subgraph Phase1["Phase 1: Device Shadowing and Asset Intelligence"]
        DID["utils/deviceid.go"]
        INV["inventory/apps.go"]
        APPS["Installed App Inventory"]
    end

    subgraph Phase2["Phase 2: Real-Time Process and Network Monitoring"]
        PRIV["config/privilege.go"]
        NETCFG["config/network.go"]
        CBRIDGE["etw/etw_bridge.c"]
        GOWRAP["etw/etw_native_engine.go"]
        EVENTS["events/events.go"]
    end

