flowchart TD
    A["cmd/agent/main.go"] --> B["Resolve device_id and hostname"]
    B --> C["Load telemetry mode config"]
    C --> D["Archive previous NDJSON outputs as Old_*"]
    D --> E["Init sinks and output manager"]
    E --> F["Enable privileges and load network config"]
    F --> G["PopulateInitialProcessTable()"]
    G --> H["Seed telemetry controller with live processes"]
    H --> I["Start correlation engine"]
    I --> J["Start ETW listener"]

    subgraph ETW["ETW Capture Layer"]
        J --> K["internal/etw/etw_bridge.c"]
        K --> L["internal/etw/etw_native_engine.go"]
        L --> M["events.ProcessChan"]
        L --> N["events.NetworkChan"]
    end

    subgraph CORR["Correlation and Genealogy"]
        M --> O["HandleProcessStart()"]
        M --> P["HandleProcessStop()"]
        O --> Q["parseProcessDetail()"]
        Q --> R["buildGenealogyChain()"]
        R --> S["Chain / Depth / ParentImage / GrandParentImage"]
        S --> T["processTable update"]
        T --> U["StructuredOutput"]
        P --> V["stop fallback and context rebuild"]
        V --> U
        N --> W["forwardNetworkEvents()"]
        W --> X["network correlation with processTable"]
        X --> Y["NetworkOutputChan"]
    end

    subgraph TELE["Telemetry Shaping"]
        U --> Z["internal/telemetry/controller.go"]
        Y --> Z
        Z --> AA["baseline mode"]
        Z --> AB["deep mode"]

        AA --> AC["process_execution_*.ndjson"]
        AA --> AD["process_edge_*.ndjson"]
        AA --> AE["network_rollup_*.ndjson"]
        AA --> AF["telemetry_mode_*.ndjson"]

        AB --> AG["deep_capture_*.ndjson.gz"]
        AB --> AF
    end

    subgraph PH1["Phase 1 Inventory"]
        E --> AH["CollectInstalledApps()"]
        AH --> AI["apps_*.ndjson"]
    end

    subgraph LEGACY["Optional Compatibility Output"]
        U --> AJ["processes_*.ndjson only when EXIONIS_WRITE_LEGACY_RAW=1"]
        Y --> AK["network_*.ndjson only when EXIONIS_WRITE_LEGACY_RAW=1"]
    end

    subgraph OBS["Operational Logs"]
        U --> AL["stdout JSON"]
        Y --> AL
        AL --> AM["output.log"]
        E --> AN["agent.ndjson"]
    end
